# Copy this file to `.env.development.local` (gitignored) and restart `npm run dev`.
# Without this, Vite proxies /api to the default hosted backend, which may not include
# poster admin routes yet — then GET /api/admin/posters returns 404 and Save/Publish fail.

# Local GuideXpert-Backend (use the port your Express app listens on, often 5000)
VITE_PROXY_TARGET=http://localhost:5000

# Optional but recommended for local admin login: same origin for all /api calls
# VITE_API_URL=http://localhost:5000/api
