# Copy to .env.development.local (gitignored) so Vite proxies /api to YOUR machine.
# Fixes 404 on Admin → WhatsApp ops when the default proxy target is production and
# production has not deployed /api/admin/whatsapp-ops yet.
#
#   cp .env.development.local.example .env.development.local
#
# Use the same port as GuideXpert-Backend (PORT in backend .env, often 5000).
VITE_PROXY_TARGET=http://127.0.0.1:5000
