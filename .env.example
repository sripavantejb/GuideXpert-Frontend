# API Configuration (deployed backend used by default)
# Default: https://guide-xpert-backend.vercel.app/api
# For local admin login: point frontend to local backend so credentials match:
#   VITE_API_URL=http://localhost:5000/api
# Then run backend (npm run dev in backend) and: cd backend && ADMIN_USERNAME=venkatesh ADMIN_PASSWORD=venkatesh node scripts/ensureAdmin.js
VITE_API_URL=https://guide-xpert-backend.vercel.app/api

# Vite dev server only: host to forward browser requests from /api/* (see vite.config.js loadEnv).
# - Use deployed backend (no local Node): set this to the backend origin WITHOUT /api:
#     VITE_PROXY_TARGET=https://guide-xpert-backend.vercel.app
# - Use local backend: run backend on port 5000 and either omit this (default) or set:
#     VITE_PROXY_TARGET=http://localhost:5000
# If this is wrong or missing when using the default VITE_API_URL to Vercel, Vite falls back to
# localhost:5000 and you will see ECONNREFUSED on /api/demo-slots etc.

# Optional: base URL for influencer UTM links (default: https://guidexpert.co.in/register)
# VITE_REGISTRATION_BASE_URL=https://guidexpert.co.in/register
