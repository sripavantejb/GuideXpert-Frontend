# API Configuration (deployed backend used by default)
# Default: https://guide-xpert-backend.vercel.app/api
# For local admin login: point frontend to local backend so credentials match:
#   VITE_API_URL=http://localhost:5000/api
# Then run backend (npm run dev in backend) and: cd backend && ADMIN_USERNAME=venkatesh ADMIN_PASSWORD=venkatesh node scripts/ensureAdmin.js
VITE_API_URL=https://guide-xpert-backend.vercel.app/api

# Vite dev server only: host to forward browser requests from /api/* (see vite.config.js loadEnv).
# Default (no env): https://guide-xpert-backend.vercel.app — same as production API host.
#
# If Admin → WhatsApp ops shows a 404 / "API not found" banner, that host lacks /api/admin/whatsapp-ops routes.
# Quickest local fix: copy .env.development.local.example → .env.development.local with VITE_PROXY_TARGET
# pointing at YOUR running backend (PORT in GuideXpert-Backend/.env), then restart `npm run dev`.
# Production fix: redeploy GuideXpert-Backend with the WhatsApp ops routes committed.
# - Explicit deployed backend (optional):
#     VITE_PROXY_TARGET=https://guide-xpert-backend.vercel.app
# - Local backend instead:
#     VITE_PROXY_TARGET=http://localhost:5000
#
# Poster automation (Admin → Posters): needs GET /api/admin/posters on whatever host receives
# proxied traffic. If you see 404 for /api/admin/posters in the browser, either deploy the
# latest GuideXpert-Backend to that host or use a local backend and set VITE_PROXY_TARGET (see
# `.env.development.local.example`).
#
# Admin → WhatsApp ops (`/api/admin/whatsapp-ops/*`): same rule — deploy latest backend or set
# VITE_PROXY_TARGET=http://localhost:<PORT> (matches your backend .env PORT, often 5000).

# Optional: base URL for influencer UTM links (default: https://guidexpert.co.in/register)
# VITE_REGISTRATION_BASE_URL=https://guidexpert.co.in/register

# Optional: full URL for IIT counselling page UTM builder in Admin → IIT Counselling UTM (no trailing ?)
# VITE_IIT_COUNSELLING_PAGE_URL=https://guidexpert.co.in/iit-counselling

# Optional: full URL to the IIT counselling landing page (no query string), for Admin → IIT Counselling UTM link builder
# VITE_IIT_COUNSELLING_PAGE_URL=https://guidexpert.co.in/iit-counselling

# Optional: match backend OSVI_OUTBOUND_DELAY_MS (ms) for Apply section browser console countdown only. Default 10000 (10 sec).
# VITE_OSVI_OUTBOUND_DELAY_MS=10000
